{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RouterValidateOutput",
  "type": "object",
  "required": ["file", "strict", "ok", "errors", "warnings"],
  "properties": {
    "file": { "type": "string", "minLength": 1 },
    "strict": { "type": "boolean" },
    "ok": { "type": "boolean" },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "message": { "type": "string", "minLength": 1 },
          "hint": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "message": { "type": "string", "minLength": 1 },
          "hint": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
