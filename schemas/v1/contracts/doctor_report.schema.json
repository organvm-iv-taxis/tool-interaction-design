{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DoctorReport",
  "type": "object",
  "required": ["ok", "checks", "summary", "autofix_hints"],
  "properties": {
    "ok": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ok", "errors", "warnings", "hints"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "ok": { "type": "boolean" },
          "errors": { "type": "array", "items": { "type": "string" } },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "hints": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["errors", "warnings", "checks_total", "checks_ok"],
      "properties": {
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "checks_total": { "type": "integer", "minimum": 0 },
        "checks_ok": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "autofix_hints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "applied_fixes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
