{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://organvm.dev/schemas/v1/risk_register.schema.json",
  "title": "Risk Register",
  "description": "Schema for the conductor risk register data file (.conductor/risks.json).",
  "type": "object",
  "properties": {
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update."
    },
    "risks": {
      "type": "object",
      "description": "Map of risk ID to risk object.",
      "additionalProperties": {
        "$ref": "#/$defs/risk"
      }
    }
  },
  "required": ["risks"],
  "additionalProperties": false,
  "$defs": {
    "risk": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^RISK-[A-F0-9]{8}$",
          "description": "Unique risk identifier."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable risk description."
        },
        "probability": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Likelihood of the risk materializing."
        },
        "impact": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Severity if the risk materializes."
        },
        "mitigation": {
          "type": "string",
          "description": "Planned mitigation strategy."
        },
        "owner": {
          "type": "string",
          "description": "Person or team responsible for managing the risk."
        },
        "status": {
          "type": "string",
          "enum": ["open", "mitigating", "resolved", "accepted"],
          "description": "Current risk status."
        },
        "created_at": {
          "type": "number",
          "description": "Unix timestamp when the risk was created."
        }
      },
      "required": ["id", "description", "probability", "impact", "mitigation", "owner", "status"],
      "additionalProperties": false
    }
  }
}
