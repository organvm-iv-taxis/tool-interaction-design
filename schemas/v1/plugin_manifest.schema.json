{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConductorPluginManifestV1",
  "type": "object",
  "required": ["api_version", "name", "capabilities", "provider"],
  "properties": {
    "api_version": { "const": "v1" },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "provider": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["python", "file"] },
        "spec": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "timeout_seconds": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 30
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "python" } },
            "required": ["kind"]
          },
          "then": { "required": ["spec"] }
        },
        {
          "if": {
            "properties": { "kind": { "const": "file" } },
            "required": ["kind"]
          },
          "then": { "required": ["path"] }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
