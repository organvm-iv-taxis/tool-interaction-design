{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Process Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "phase",
    "owner",
    "status",
    "risk_level",
    "estimate_points",
    "acceptance_criteria",
    "definition_of_done",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^WI-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "phase": {
      "type": "string",
      "enum": ["discover", "design", "build", "verify", "release", "operate"]
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role"],
      "properties": {
        "name": {"type": "string", "minLength": 2},
        "role": {"type": "string", "minLength": 2}
      }
    },
    "status": {
      "type": "string",
      "enum": ["backlog", "in_progress", "blocked", "done"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "estimate_points": {
      "type": "integer",
      "minimum": 1,
      "maximum": 13
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 4}
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WI-[0-9]{4}$"
      },
      "uniqueItems": true
    },
    "definition_of_done": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tests_passed",
        "docs_updated",
        "changelog_updated",
        "demo_recorded",
        "evidence"
      ],
      "properties": {
        "tests_passed": {"type": "boolean"},
        "docs_updated": {"type": "boolean"},
        "changelog_updated": {"type": "boolean"},
        "demo_recorded": {"type": "boolean"},
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pr_url", "ci_url", "demo_url"],
          "properties": {
            "pr_url": {"type": "string", "format": "uri"},
            "ci_url": {"type": "string", "format": "uri"},
            "demo_url": {"type": "string", "format": "uri"}
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
